# X11 display for GUI applications
DISPLAY=:0

# Host folder where datasets are stored
DOCKER_DATASETS=/home/afrl/dataset

# Host folder where the workspace exists
CATKIN_WS=/home/afrl/sqrt_ws

# Dataset category (e.g., euroc_mav)
# config:['euroc_mav', 'uzhfpv_indoor', 'uzhfpv_indoor_45', 'uzhfpv_outdoor', 'uzhfpv_outdoor_45']

CONFIG=grand_tour_stereo
MAX_CAMERAS=2
USE_STEREO=true

# Dataset sequence name (e.g., MH_01_easy, V1_01_easy)
DATASET=2024-11-18-12-05-01

# Folder inside container where bag files are located
BAG=/datasets/grand_tour/group_6
BAG_START=0.0

# Host folder for saving output results
RESULT_PATH=/home/afrl/sqrt_test

HISTGRAM_METHOD=CLAHE
INIT_DNY_USE=false
